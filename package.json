{
  "name": "stego-extension",
  "displayName": "Stego Bible Links",
  "description": "Auto-link Bible identifiers like LOC-ASDF in Markdown manuscripts.",
  "version": "0.0.1",
  "publisher": "matt-gold",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:stegoBible.reloadIndex",
    "onCommand:stegoBible.runBuild",
    "onCommand:stegoBible.runGateStage",
    "onCommand:stegoBible.addComment",
    "onCommand:stegoBible.toggleFrontmatter",
    "onView:stegoBible.metadataView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "stegoBible",
          "title": "Stego",
          "icon": "assets/stego.svg"
        }
      ]
    },
    "views": {
      "stegoBible": [
        {
          "id": "stegoBible.metadataView",
          "name": "Metadata",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "stegoBible.reloadIndex",
        "title": "Stego Bible: Rebuild Index"
      },
      {
        "command": "stegoBible.runBuild",
        "title": "Build Manuscript",
        "icon": "$(file)"
      },
      {
        "command": "stegoBible.runGateStage",
        "title": "Run Stage Checks",
        "icon": "$(check)"
      },
      {
        "command": "stegoBible.toggleFrontmatter",
        "title": "Stego Bible: Toggle Frontmatter Fold"
      },
      {
        "command": "stegoBible.addComment",
        "title": "Stego: Add Comment"
      }
    ],
    "keybindings": [
      {
        "command": "stegoBible.addComment",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "stegoBible.runBuild",
          "when": "view == stegoBible.metadataView",
          "group": "navigation@1"
        },
        {
          "command": "stegoBible.runGateStage",
          "when": "view == stegoBible.metadataView",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Stego",
      "properties": {
        "stego.bible.identifierPattern": {
          "type": "string",
          "default": "\\b[A-Z][A-Z0-9]*-[A-Z0-9]+(?:-[A-Z0-9]+)*\\b",
          "description": "Regex used to find Bible identifiers in Markdown text (for example LOC-ASDF or CHAR-JANE)."
        },
        "stego.bible.indexFile": {
          "type": "string",
          "default": ".stego/bible-index.json",
          "description": "Path to the workspace JSON file containing identifier definitions. If missing or partial, Stego also infers entries from project.json bible category prefixes and markdown headings."
        },
        "stego.bible.definitionBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Optional fallback base URL used when an identifier has no explicit URL or path in the index."
        },
        "stego.bible.reportUnknownIdentifiers": {
          "type": "boolean",
          "default": true,
          "description": "Warn when identifiers are found in text but missing from the index file."
        },
        "stego.editor.enableHover": {
          "type": "boolean",
          "default": true,
          "description": "Show identifier details on hover."
        },
        "stego.editor.linkInCodeFences": {
          "type": "boolean",
          "default": false,
          "description": "Create links inside fenced code blocks."
        },
        "stego.editor.autoFoldFrontmatter": {
          "type": "boolean",
          "default": true,
          "description": "Automatically fold YAML frontmatter in Markdown files."
        },
        "stego.comments.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the comments feature. When disabled, no comment parsing, gutter decorations, or comments tab will appear."
        },
        "stego.comments.author": {
          "type": "string",
          "default": "",
          "description": "Default author name used when adding sidebar comments. Leave blank to use your system/git username."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "test:pure": "npm run compile && node --test out/test/pure/*.js"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.92.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "dayjs": "^1.11.19",
    "js-yaml": "^4.1.0",
    "markdown-it": "^14.1.1"
  }
}
